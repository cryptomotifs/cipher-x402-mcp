{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/health", "destination": "/api/index" }
  ],
  "functions": {
    "api/mcp.ts": {
      "maxDuration": 30,
      "runtime": "@vercel/node@5.1.10"
    },
    "api/index.ts": {
      "runtime": "@vercel/node@5.1.10"
    }
  }
}
